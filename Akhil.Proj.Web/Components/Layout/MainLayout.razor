@inherits LayoutComponentBase


<div class="page @(AppState.IsLightMode ? "light-theme" : "")">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <!-- Top row header -->
        <header class="top-row px-4 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-church text-primary fs-3"></i>
                <h4 class="m-0 font-heading fw-bold d-none d-sm-block">CHRIST MIRACLE CHURCH</h4>
            </div>
            
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-premium-secondary d-flex align-items-center gap-1" @onclick="ToggleTheme" style="font-size: 0.8rem; padding: 0.4rem 0.8rem;">
                    @if (AppState.IsLightMode)
                    {
                        <i class="bi bi-moon-stars-fill text-warning"></i> <span>Dark Mode</span>
                    }
                    else
                    {
                        <i class="bi bi-sun-fill text-accent"></i> <span>Light Mode</span>
                    }
                </button>

                @if (AppState.CurrentUser != null)
                {
                    <div class="d-flex align-items-center gap-2">
                        <div class="avatar-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; border-radius: 50%; font-weight: bold; font-size: 0.9rem;">
                            @AppState.CurrentUser.Name[0].ToString().ToUpper()
                        </div>
                        <div class="text-end d-none d-md-block" style="line-height: 1.1;">
                            <div class="small fw-semibold text-white">@AppState.CurrentUser.Name</div>
                            <span class="badge bg-dark border border-secondary text-secondary" style="font-size: 0.65rem;">@AppState.ActiveRole</span>
                        </div>
                    </div>
                    
                    @if (AppState.ActiveRole == "Admin")
                    {
                        <a href="admin" class="btn btn-sm btn-outline-warning d-none d-sm-inline-flex align-items-center gap-1">
                            <i class="bi bi-shield-lock"></i> Console
                        </a>
                    }
                    
                    <button class="btn btn-sm btn-outline-danger" title="Log Out" @onclick="Logout">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                }
                else
                {
                    @*
                    <a href="register" class="btn btn-sm btn-premium-secondary me-2">
                        <i class="bi bi-person-plus"></i> Register
                    </a>
                    <a href="auth" class="btn btn-sm btn-premium">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </a>
                    *@
                }
            </div>
        </header>

        <!-- Main Body -->
        <article class="content px-3 px-md-4">
            @Body
        </article>
    </main>
</div>

<!-- Mobile Bottom Navigation Bar -->
<div class="mobile-nav-bar">
    <NavLink href="" Match="NavLinkMatch.All" class="mobile-nav-item">
        <i class="bi bi-house"></i>
        <span>Home</span>
    </NavLink>
    @if (AppState.ActiveRole == "Admin")
    {
        <NavLink href="registrations" class="mobile-nav-item">
            <i class="bi bi-people"></i>
            <span>Members</span>
        </NavLink>
    }
    <NavLink href="news" class="mobile-nav-item">
        <i class="bi bi-journal-text"></i>
        <span>Feed</span>
    </NavLink>
    <NavLink href="gallery" class="mobile-nav-item">
        <i class="bi bi-images"></i>
        <span>Gallery</span>
    </NavLink>
    <NavLink href="events" class="mobile-nav-item">
        <i class="bi bi-calendar-event"></i>
        <span>Events</span>
    </NavLink>
    <NavLink href="prayer" class="mobile-nav-item">
        <i class="bi bi-heart"></i>
        <span>Prayer</span>
    </NavLink>
    <NavLink href="live" class="mobile-nav-item">
        <i class="bi bi-broadcast text-danger"></i>
        <span>Live</span>
    </NavLink>
</div>

<!-- Dynamic Push Notification Alert overlay -->
@if (_activeAlert != null)
{
    <div class="notification-banner">
        <div class="bg-primary text-white p-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; flex-shrink: 0;">
            <i class="bi bi-bell-fill fs-5"></i>
        </div>
        <div class="flex-grow-1">
            <h6 class="m-0 fw-bold text-white">@_activeAlert.Title</h6>
            <p class="m-0 small text-secondary mt-1">@_activeAlert.Message</p>
        </div>
        <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="DismissAlert"></button>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

