@page "/admin"

<PageTitle>CHRIST MIRACLE CHURCH - Administrative Console</PageTitle>

@if (AppState.ActiveRole != "Admin")
{
    <!-- ADMIN LOCKOUT SCREEN -->
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 text-center">
            <div class="glass-panel py-5 px-4 shadow">
                <i class="bi bi-shield-lock text-warning display-3 mb-3 d-block"></i>
                <h3 class="font-heading text-white fw-bold">Admin Portal Restricted</h3>
                <p class="text-secondary small mx-auto mb-4" style="max-width: 400px;">
                    This section contains registered member directories, GDPR-protected contact info, and server controls. 
                </p>
                
                <div class="glass-panel bg-dark bg-opacity-20 my-4 text-start">
                    <span class="badge bg-warning text-dark mb-2">Demo Bypass Option</span>
                    <p class="small text-muted m-0">
                        You can sign in instantly using the demo administrator credentials.
                    </p>
                </div>

                <div class="d-flex flex-column gap-2 mt-3">
                    <button class="btn btn-premium-accent justify-content-center" @onclick="LoginAsAdminDemo">
                        <i class="bi bi-key-fill"></i> Log In as Demo Admin
                    </button>
                    <a href="" class="btn btn-premium-secondary justify-content-center">
                        <i class="bi bi-arrow-left"></i> Return Home
                    </a>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- FULL ADMIN DASHBOARD -->
    <div class="row g-4">
        
        <!-- Dashboard Header -->
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="font-heading text-white fw-bold m-0">Admin Console</h2>
                <p class="text-secondary small m-0">System configuration, member registries, media approvals, and broadcasts.</p>
            </div>
            <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-person-badge"></i> Authenticated Admin</span>
        </div>

        <!-- METRICS CARDS -->
        <div class="col-md-3 col-sm-6">
            <div class="glass-card text-center p-3">
                <span class="text-muted small uppercase fw-semibold">Total Members</span>
                <h2 class="font-heading text-white fw-bold display-6 mt-1 mb-0">@AppState.Members.Count</h2>
                <span class="text-success small" style="font-size: 0.7rem;"><i class="bi bi-graph-up"></i> Live Directory</span>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="glass-card text-center p-3">
                <span class="text-muted small uppercase fw-semibold">Active Prayers</span>
                <h2 class="font-heading text-white fw-bold display-6 mt-1 mb-0">@AppState.Prayers.Count</h2>
                <span class="text-primary small" style="font-size: 0.7rem;"><i class="bi bi-heart-pulse"></i> Wall Requests</span>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="glass-card text-center p-3">
                <span class="text-muted small uppercase fw-semibold">Total RSVPs</span>
                <h2 class="font-heading text-white fw-bold display-6 mt-1 mb-0">@GetTotalRSVPs()</h2>
                <span class="text-accent small" style="font-size: 0.7rem;"><i class="bi bi-check2-all"></i> Event Attendance</span>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="glass-card text-center p-3">
                <span class="text-muted small uppercase fw-semibold">Pending Photos</span>
                <h2 class="font-heading text-white fw-bold display-6 mt-1 mb-0">@AppState.GalleryImages.Count(g => !g.IsApproved)</h2>
                <span class="text-warning small" style="font-size: 0.7rem;"><i class="bi bi-hourglass-split"></i> Awaiting Review</span>
            </div>
        </div>

        <!-- MEMBERS DIRECTORY SECTION -->
        <div class="col-lg-8">
            <div class="glass-panel h-100">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                    <h4 class="font-heading text-white fw-bold m-0"><i class="bi bi-people text-primary"></i> Registered Members</h4>
                    <button class="btn btn-sm btn-premium" @onclick="ExportMembersToCSV">
                        <i class="bi bi-file-earmark-excel"></i> Export to Excel (CSV)
                    </button>
                </div>

                <!-- Search box -->
                <div class="input-group mb-3">
                    <span class="input-group-text bg-dark border-secondary border-opacity-20 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control form-glass" placeholder="Search members by name, email, referral source..." @bind="_searchQuery" @bind:event="oninput" />
                </div>

                <!-- Members Table -->
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-dark table-hover table-striped align-middle border border-secondary border-opacity-10">
                        <thead>
                            <tr class="small text-secondary">
                                <th>Name</th>
                                <th>Email / Phone</th>
                                <th>Referral</th>
                                <th>Family</th>
                                <th>Interests</th>
                            </tr>
                        </thead>
                        <tbody class="small text-light">
                            @if (GetFilteredMembers().Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">No matching registered members found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var member in GetFilteredMembers())
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold text-white">@member.Name</div>
                                            <span class="text-muted" style="font-size: 0.7rem;">Joined @member.JoinedDate.ToString("MM/dd/yyyy")</span>
                                        </td>
                                        <td>
                                            <div class="fw-mono">@member.Email</div>
                                            <div class="text-secondary" style="font-size: 0.75rem;">@member.Phone</div>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@member.HowHeard</span>
                                        </td>
                                        <td>@member.FamilyMembers</td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-1">
                                                @foreach (var tag in member.Interests)
                                                {
                                                    <span class="badge bg-primary bg-opacity-20 text-primary" style="font-size: 0.65rem;">@tag</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- BROADCAST PUSH NOTIFICATIONS -->
        <div class="col-lg-4">
            <div class="glass-panel h-100 d-flex flex-column justify-content-between">
                <div>
                    <h4 class="font-heading text-white fw-bold mb-3"><i class="bi bi-bell text-primary"></i> Broadcast Alert</h4>
                    <p class="text-secondary small mb-4">Simulate sending a real-time push notification to all congregation members' phones.</p>

                    @if (_broadcastSuccess)
                    {
                        <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
                            <i class="bi bi-check-circle-fill"></i>
                            <span class="small">Broadcast dispatched successfully! It has dropped down at the top of your screen as a demonstration.</span>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label text-secondary small">Notification Title</label>
                        <input type="text" class="form-control form-glass" @bind="_broadcastTitle" placeholder="e.g. Prayer Meeting Tonight!" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small">Message Body</label>
                        <textarea class="form-control form-glass" rows="4" @bind="_broadcastMessage" placeholder="e.g. Don't forget, Bible Study starts in 1 hour. See you in the Chapel!"></textarea>
                    </div>
                </div>

                <button class="btn btn-premium w-100 py-2.5 mt-3 justify-content-center" @onclick="SendBroadcast">
                    <i class="bi bi-broadcast text-white"></i> Dispatch Push Notification
                </button>
            </div>
        </div>

        <!-- PENDING PHOTOS MODERATION QUEUE -->
        <div class="col-12 mt-2">
            <div class="glass-panel">
                <h4 class="font-heading text-white fw-bold mb-4"><i class="bi bi-shield-check text-primary"></i> Gallery Moderation Panel</h4>
                
                @{
                    var pendingList = AppState.GalleryImages.Where(g => !g.IsApproved).ToList();
                }

                @if (pendingList.Count == 0)
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-check2-circle fs-2 d-block mb-1"></i>
                        <span class="small">Photo queue is clean. No user-submitted gallery media requires moderation review.</span>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var pending in pendingList)
                        {
                            <div class="col-sm-6 col-md-4 col-lg-3">
                                <div class="glass-card p-2 text-start">
                                    <div class="ratio ratio-4x3 overflow-hidden rounded mb-2 border border-secondary border-opacity-10">
                                        <img src="@pending.ImageUrl" class="img-fluid object-fit-cover w-100 h-100" alt="Pending verification image" />
                                    </div>
                                    <h6 class="text-white fw-bold text-truncate m-0">@pending.Caption</h6>
                                    <span class="text-muted d-block" style="font-size: 0.75rem;">Category: @pending.Album</span>
                                    <span class="text-muted d-block mb-3" style="font-size: 0.75rem;">By: @pending.UploadedBy</span>
                                    
                                    <div class="d-flex gap-2 justify-content-between">
                                        <button class="btn btn-sm btn-outline-danger w-50" @onclick="() => RejectPhoto(pending.Id)">Reject</button>
                                        <button class="btn btn-sm btn-success w-50" @onclick="() => ApprovePhoto(pending.Id)">Approve</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

    </div>
}

